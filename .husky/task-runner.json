{
  "$schema": "https://alirezanet.github.io/Husky.Net/schema.json",
  "tasks": [
    {
      "name": "dotnet-format",
      "group": "pre-commit",
      "command": "dotnet",
      "args": [
        "format",
        "mcp-mssql.slnx",
        "--verify-no-changes",
        "--verbosity",
        "minimal"
      ],
      "include": [
        "**/*.cs",
        "**/*.csproj",
        "**/*.props",
        "**/*.targets",
        "**/*.slnx",
        ".editorconfig"
      ]
    },
    {
      "name": "dotnet-build",
      "group": "pre-commit",
      "command": "dotnet",
      "args": [
        "build",
        "mcp-mssql.slnx",
        "--configuration",
        "Release"
      ],
      "include": [
        "**/*.cs",
        "**/*.csproj",
        "**/*.props",
        "**/*.targets",
        "**/*.slnx",
        "global.json",
        "**/packages.lock.json"
      ]
    }
  ]
}
